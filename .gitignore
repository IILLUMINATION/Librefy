# OS / editor noise
.DS_Store
Thumbs.db
*.swp
*~

# Local SQLite databases — never commit them, they contain user data.
*.db
*.db-journal
*.db-shm
*.db-wal
librefy.db*

# Local environment / secrets
.env
.env.local
*.token

# Go build artifacts
/backend/librefyd
/backend/librefyd-*
/backend/cmd/librefyd/librefyd

# Per-IDE
.idea/workspace.xml
.idea/tasks.xml
.idea/dictionaries/
*.iml.tmp

# Generated native bridge headers / objects (regenerated by build-native.sh)
/native/librefy-torrent/liblibrefy_torrent.h
/native/librefy-torrent/liblibrefy_torrent.so

# Per-build native binaries that should be produced from sources, not
# checked into git. CI (and devs running scripts/build-native*.sh) puts
# them here on demand.
/app/linux/libs/*.so
/app/android/app/src/main/jniLibs/*/*.so
/app/android/app/src/main/jniLibs/*/*.h
